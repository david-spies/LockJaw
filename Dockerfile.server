FROM python:3.12-slim

LABEL maintainer="lockjaw"
LABEL description="LockJaw hybrid encryption messaging server"

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY crypto/ ./crypto/
COPY backend/server.py .

# Non-root user
RUN useradd -r -s /bin/false lockjaw
USER lockjaw

EXPOSE 8765

CMD ["python", "server.py"]
